{
	"info": {
		"name": "alizia-inclusion",
		"description": "Coleccion completa de alizia-inclusion-be (35 requests).\n\nEjecutar con Newman o como Runner en Postman — el flujo es secuencial.\n\n1. Login guarda token automaticamente\n2. Creates guardan IDs en variables\n3. Updates/Deletes usan esos IDs dinamicos\n4. Nunca toca datos seed\n\nUsuarios demo: docente1@demo.edu / demo123, admin@demo.edu / demo123",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url", "value": "http://localhost:8080/api/v1" },
		{ "key": "token", "value": "" },
		{ "key": "created_classroom_id", "value": "" },
		{ "key": "created_student_id", "value": "" },
		{ "key": "created_adaptation_id", "value": "" }
	],
	"auth": {
		"type": "bearer",
		"bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
	},
	"item": [
		{
			"name": "01 - Health & Auth",
			"item": [
				{
					"name": "Health Check",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Health OK', function() { pm.response.to.have.status(200); });"
					]}}],
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "http://localhost:8080/health", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["health"] },
						"auth": { "type": "noauth" }
					}
				},
				{
					"name": "Login (docente1)",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Login OK', function() { pm.response.to.have.status(200); });",
						"var json = pm.response.json();",
						"var token = json.description ? json.description.token : json.token;",
						"pm.collectionVariables.set('token', token);",
						"console.log('Token saved');"
					]}}],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n    \"email\": \"docente1@demo.edu\",\n    \"password\": \"demo123\"\n}" },
						"url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
						"auth": { "type": "noauth" }
					}
				},
				{
					"name": "Login (admin)",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Login admin OK', function() { pm.response.to.have.status(200); });",
						"var json = pm.response.json();",
						"var token = json.description ? json.description.token : json.token;",
						"pm.collectionVariables.set('token', token);",
						"console.log('Token switched to admin');"
					]}}],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n    \"email\": \"admin@demo.edu\",\n    \"password\": \"demo123\"\n}" },
						"url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
						"auth": { "type": "noauth" }
					}
				},
				{
					"name": "Login back (docente1)",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"var json = pm.response.json();",
						"var token = json.description ? json.description.token : json.token;",
						"pm.collectionVariables.set('token', token);"
					]}}],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n    \"email\": \"docente1@demo.edu\",\n    \"password\": \"demo123\"\n}" },
						"url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
						"auth": { "type": "noauth" }
					}
				},
				{
					"name": "Get Me",
					"event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
						"pm.test('Get Me OK', function() { pm.response.to.have.status(200); });",
						"var json = pm.response.json();",
						"var user = json.description || json;",
						"pm.test('Has email', function() { pm.expect(user.email).to.eql('docente1@demo.edu'); });"
					]}}],
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
					}
				}
			]
		},
